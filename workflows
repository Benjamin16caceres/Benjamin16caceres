name: Generate Snake Animation

on:
  schedule:
    - cron: "0 5 * * *"   # se actualiza todos los días a las 05:00 UTC
  workflow_dispatch: {}    # te permite ejecutarlo manualmente desde la pestaña Actions
  push:
    branches:
      - main

jobs:
  generate:
    permissions:
      contents: write
    runs-on: ubuntu-latest
    steps:
      - name: Generar SVG de la snake
        uses: Platane/snk@v3
        with:
          github_user_name: ${{ github.repository_owner }}
          outputs: |
            dist/snake-dark.svg?palette=github-dark
            dist/snake.svg

      - name: Publicar en la rama "output"
        uses: crazy-max/ghaction-github-pages@v4
        with:
          target_branch: output
          build_dir: dist
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
